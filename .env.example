# ==========================================================================
# ClaudeWake — variáveis de ambiente
# Copie este arquivo para .env.local (desenvolvimento) e configure na Vercel
# (produção). NUNCA comite o .env.local — ele contém segredos.
# ==========================================================================

# --- Autenticação do painel ---------------------------------------------
# Usuário e senha para acessar o painel. Escolha valores fortes.
APP_USERNAME=admin
APP_PASSWORD=troque-esta-senha

# Segredo usado para assinar o cookie de sessão.
# Gere um valor aleatório, por exemplo:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=coloque-um-valor-aleatorio-de-64-caracteres

# Chave para criptografar o token do Claude no banco (AES-256-GCM).
# Gere outro valor aleatório (diferente do SESSION_SECRET).
TOKEN_ENCRYPTION_KEY=coloque-outro-valor-aleatorio-de-64-caracteres

# --- Upstash Redis (Níveis 3+) ------------------------------------------
# Painel Upstash > seu banco Redis > REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Upstash QStash (Nível 6) -------------------------------------------
# Painel Upstash > QStash. A URL depende da região escolhida
# (ex.: https://qstash-us-east-1.upstash.io). Deixe em branco para a padrão.
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- URL pública do app (Nível 6) ---------------------------------------
# Em produção, a URL da Vercel (ex.: https://claude-alarm.vercel.app).
# Em desenvolvimento, use um túnel (ngrok) se for testar o QStash localmente.
APP_URL=http://localhost:3000
